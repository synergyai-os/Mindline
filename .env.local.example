# Copy this file to .env.local and add your local provider key.
# Never commit .env.local.

# First provider for WP-17 local testing.
MINDLINE_LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# Future provider slots. Leave blank unless using that provider.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Privacy-safe observability. Phase 0 is metadata-only and disabled by default.
MINDLINE_TELEMETRY_ENABLED=false
MINDLINE_LLM_TRACE_MODE=metadata
MINDLINE_TELEMETRY_SALT=
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
